# Docker Hub username (for pulling images)
DOCKER_USERNAME=your-dockerhub-username

# Image tag (use 'latest' or a specific version like 'v1.0.0')
TAG=latest

# Database credentials (CHANGE THESE!)
POSTGRES_USER=catholic_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=catholic_ride_share
DATABASE_URL=postgresql://catholic_user:CHANGE_ME_strong_password_here@db:5432/catholic_ride_share

# Application secret key (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_generate_a_random_secret_key

# API URL that the frontend uses (your server's domain or IP)
# If using a domain: https://yourdomain.com/api/v1
# If using IP: http://YOUR_VPS_IP/api/v1
API_BASE_URL=http://YOUR_VPS_IP/api/v1

# CORS origins (JSON list for FastAPI settings; include your frontend domain)
ALLOWED_ORIGINS=["https://catholicrides.org", "https://www.catholicrides.org"]

# Stripe donations (optional, but required for per-ride donations)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid Email Settings (required for email verification and notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_your_sendgrid_api_key
EMAILS_FROM_EMAIL=noreply@catholicrides.org
EMAILS_FROM_NAME="Catholic Ride Share"

